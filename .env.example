# =============================================================================
# CML-MCP Server Configuration
# =============================================================================
# Copy this file to .env and configure the values below.
# All variables have sensible defaults except for CML connection settings.
#
# For stdio mode: CML_USERNAME and CML_PASSWORD are required.
# For HTTP mode: Credentials are provided per-request via the X-Authorization
# header. CML_USERNAME and CML_PASSWORD are ignored in HTTP mode unless you
# also set CML_MCP_ALLOW_UNAUTHENTICATED=true (see warning below).
# =============================================================================

# -----------------------------------------------------------------------------
# CML Server Connection
# -----------------------------------------------------------------------------

# URL of the Cisco Modeling Labs server (required for stdio mode)
CML_URL=https://cml.example.com

# CML authentication credentials (required for stdio mode only)
# In HTTP mode, credentials are passed via X-Authorization header. They will
# only be used as a fallback for requests with no X-Authorization header if
# CML_MCP_ALLOW_UNAUTHENTICATED=true is ALSO set.
#
# !!!WARNING In HTTP mode, setting these values AND
# CML_MCP_ALLOW_UNAUTHENTICATED=true allows ANY client that can reach the
# server port to assume these credentials without authenticating. Only enable
# the combination for trusted, single-tenant deployments!!!
CML_USERNAME=
CML_PASSWORD=

# Skip TLS certificate verification (useful for self-signed certs)
# It is set to false in this example file since CML ships with a self-signed
# certificate.  If you install a proper cert, or add CML's self-signed cert
# to your trusted store, you SHOULD set this to true for better security.
# Values: true, false
CML_VERIFY_SSL=false

# -----------------------------------------------------------------------------
# MCP Server Transport Configuration
# -----------------------------------------------------------------------------

# Transport mode: stdio or http
# - stdio: Direct communication via stdin/stdout
# - http: HTTP server with streaming (for remote access / multi-client / multi-server)
CML_MCP_TRANSPORT=stdio

# HTTP server bind address (only used when CML_MCP_TRANSPORT=http)
CML_MCP_BIND=0.0.0.0

# HTTP server port (only used when CML_MCP_TRANSPORT=http)
CML_MCP_PORT=9000

# Allow requests with no X-Authorization header to fall back to the
# CML_USERNAME/CML_PASSWORD configured above (HTTP mode only). When false
# (the default), HTTP requests without an X-Authorization header are
# rejected. Set to true ONLY for trusted single-tenant deployments where
# every client is allowed to act as the configured identity.
# Values: true, false
CML_MCP_ALLOW_UNAUTHENTICATED=false

# -----------------------------------------------------------------------------
# HTTP Per-Request URL Configuration
# -----------------------------------------------------------------------------

# Note: for per-request URLs to work at least one of the following must be set.
# These variables are only processed when CML_MCP_TRANSPORT=http.

# Allow list of URLs for per-request CML server connections.
# Comma-separated list of URLs. Leave empty to allow all.
CML_ALLOWED_URLS=

# Regular expression pattern for allowed per-request CML server URLs.
# Leave empty to disable.
CML_URL_PATTERN='^https://cml\\.example\\.com'

# -----------------------------------------------------------------------------
# PyATS Configuration (Optional)
# -----------------------------------------------------------------------------
# Required for CLI command execution on running devices.
# If not set, defaults to "cisco" for all credentials.

# Device login username
PYATS_USERNAME=cisco

# Device login password
PYATS_PASSWORD=cisco

# Device enable/privileged mode password
PYATS_AUTH_PASS=cisco

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------

# Enable debug logging
# Values: true, false
DEBUG=false
